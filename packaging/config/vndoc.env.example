# ==========================================================================
# VNDoc OCR Service — cấu hình vận hành (DOC-11 §7)
# Bộ cài chép file này thành  <install>\config\vndoc.env  (chỉ khi chưa có).
# Admin sửa xong phải RESTART service:  sc stop VNDocOCR  &&  sc start VNDocOCR
# Khoá theo tiền tố DIP_ (settings.py, env_prefix="DIP_").
# ==========================================================================

# --- Bảo mật (NFR-007) ------------------------------------------------------
# API Key dùng chung: client Android phải gửi header  X-API-Key: <chuỗi này>.
# ⚙️ Bộ cài TỰ SINH key ngẫu nhiên khi cài lần đầu (nếu để trống). Đổi tay được.
# ĐỂ TRỐNG = KHÔNG bắt buộc key (chỉ nên dùng khi mạng đã cô lập chặt).
DIP_API_KEY=

# Whitelist IP được phép gọi service (CIDR, ngăn bằng dấu phẩy). Vì thiết bị Android
# CÙNG LAN với máy (không gọi được qua 127.0.0.1), service bind 0.0.0.0 nhưng CHỈ cho
# các dải dưới đây truy cập; client ngoài dải → 403.
# Sửa cho khớp subnet LAN của đơn vị (vd 192.168.1.0/24, 10.0.0.0/24).
#
# TESTING — CHO PHÉP MỌI IP (KHÔNG giới hạn): đặt  DIP_ALLOWED_IPS=*
#   (để trống, 'all', hoặc '0.0.0.0/0' cũng như vậy). CHỈ dùng khi test, KHÔNG dùng thật.
DIP_ALLOWED_IPS=127.0.0.1/32,192.168.0.0/24

# --- Mạng -------------------------------------------------------------------
# 0.0.0.0 = nghe mọi giao diện để Android trong LAN gọi được (an toàn nhờ whitelist
# ở trên). Muốn khoá chỉ nội bộ máy thì đổi thành 127.0.0.1.
DIP_HOST=0.0.0.0
DIP_PORT=11001

# --- Corner-detector fallback -----------------------------------------------
# Nắn tốt hơn ảnh thẻ NHỎ trên nền nhiễu/nghiêng: dùng model góc ONNX khi thẻ chiếm ít
# khung; thẻ lấp khung vẫn dùng classic. Cần models\corner.onnx (đã bundle). Đặt false để tắt.
DIP_RECTIFY_CORNER_FALLBACK=true

# --- Hiệu năng / thiết bị ---------------------------------------------------
# auto = tự dùng NVIDIA CUDA nếu có, ngược lại CPU. Ép: cpu | cuda.
DIP_OCR_DEVICE=auto
# Số request OCR chạy song song (khởi điểm ~ số P-core i7-14700).
DIP_MAX_CONCURRENCY=8
# Số luồng torch cho recognition (CPU).
DIP_OCR_THREADS=8
# Timeout mỗi request (giây). OCR ảnh xoay có thể ~5s → để rộng tránh 429 oan.
DIP_REQUEST_TIMEOUT_SEC=15

# --- Đường dẫn (thường KHÔNG cần sửa — launcher tự trỏ theo thư mục cài) -----
# DIP_MODELS_DIR=C:\Program Files\VNDoc\models
# DIP_PLUGINS_DIR=C:\Program Files\VNDoc\plugins

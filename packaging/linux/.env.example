# Sao chép thành  packaging/linux/.env  rồi sửa. docker compose tự đọc file này.
# API key dùng chung (client Android gửi header X-API-Key). Để trống = entrypoint tự sinh mỗi lần chạy.
DIP_API_KEY=
# Whitelist IP (CIDR, phẩy ngăn). Trống = mọi IP (chỉ test). Vd: 127.0.0.1/32,192.168.1.0/24
DIP_ALLOWED_IPS=
# Hiệu năng theo CPU host.
DIP_OCR_THREADS=8
DIP_MAX_CONCURRENCY=8
DIP_REQUEST_TIMEOUT_SEC=15

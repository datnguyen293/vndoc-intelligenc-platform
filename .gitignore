# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.venv/
venv/
.env

# --- Model weights / log / OS ---
# Anchor đúng thư mục weights ML (KHÔNG nuốt package code app/models/).
# Bỏ ignore mặc định cho THƯ MỤC (dùng /* ) rồi RE-INCLUDE các weights đã chốt version
# (quyết định 2026-07-02: đưa model vào repo để clone/Docker khỏi copy tay). File weights
# MỚI (chưa liệt kê) vẫn bị ignore để tránh commit nhầm.
/service/models/*
!/service/models/vgg_seq2seq.pth
!/service/models/corner.onnx
!/service/models/orientation.onnx
!/service/models/orientation.json
/models/
service/logs/
*.log
.DS_Store

# --- Đóng gói (DOC-11): artifact build nặng, KHÔNG commit ---
# (comment phải ở DÒNG RIÊNG — git coi '# ...' cùng dòng là một phần của pattern)
/build/
# nssm.exe (tự tải, public-domain)
/packaging/bin/
# Python nhúng + deps (tự tải, ~1.5GB)
/packaging/runtime/
# bộ cài .exe do Inno sinh ra
/packaging/installer/Output/

# --- Tooling cục bộ ---
.claude/settings.local.json

# --- DỮ LIỆU CÁ NHÂN THẬT: KHÔNG commit (ảnh giấy tờ tuỳ thân, NFR-007) ---
*.jpg
*.jpeg
*.png
*.webp
*.gif
*.bmp
docs/logs/

# Docker Compose secrets (Linux packaging)
packaging/linux/.env
